# Auth Service Environment Variables
# Copy to .env and fill in your values

# ── Application ───────────────────────────────
PORT=3001
NODE_ENV=development

# ── Database ──────────────────────────────────
DATABASE_URL="postgresql://traffic_user:traffic_pass@localhost:5432/auth_db?schema=public"

# ── JWT ───────────────────────────────────────
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# ── Bcrypt ────────────────────────────────────
BCRYPT_ROUNDS=10
