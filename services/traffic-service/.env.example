# Traffic Service Environment Variables
# Copy to .env and fill in your values

# ── Application ───────────────────────────────
PORT=3003
NODE_ENV=development
TRAFFIC_SIMULATION_ENABLED=true
TRAFFIC_SIMULATION_INTERVAL_SECONDS=300

# ── Database ──────────────────────────────────
DATABASE_URL="postgresql://traffic_user:traffic_pass@localhost:5432/traffic_db?schema=public"
